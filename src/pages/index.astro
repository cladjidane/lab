---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects";

function getProject(slug: string) {
  return projects.find((p) => p.slug === slug);
}

const waveBars = [10, 16, 8, 20, 6, 14, 10, 24, 12, 18, 7, 16];
const dictWave = [4, 8, 5, 11, 3, 7, 9, 5];
---

<Layout title="Fabien Canu — FC Lab · Portfolio IA" description="25 ans de code, l'IA comme levier. ~20 produits IA en 18 mois : PAI (mémoire persistante), Jaja (assistant vocal), Uptake, Vokable, Epicycle Draw, et plus. Terrain d'essai pour l'IA appliquée.">
  <main class="bento-grid bg-surface">
    <!-- ================= ROW 1-2 : TROIS STARS ================= -->

    <!-- FC Branding (c1 r1) -->
    <div
      class="bento-tile bg-on-surface grain-kraft flex flex-col items-center justify-center text-center overflow-hidden"
      style="grid-column: 1; grid-row: 1;"
      data-info="about"
    >
      <span class="font-headline text-5xl font-bold text-white tracking-tighter leading-none">FC</span>
      <span class="font-headline text-[9px] uppercase tracking-[0.3em] text-white/50 mt-2">Lab · 2026</span>
      <div class="absolute bottom-1.5 left-1.5 w-2 h-2 rounded-full bg-brand-cyan" style="z-index:2;"></div>
    </div>

    <!-- PAI hero (c2-3, r1-2) -->
    {(() => {
      const p = getProject("pai")!;
      return (
        <div
          class="bento-tile bento-bg-cyan grain-paper flex flex-col justify-end p-8 overflow-hidden"
          style="grid-column: 2 / 4; grid-row: 1 / 3;"
          data-slug={p.slug}
        >
          <div>
            <span class="font-headline text-[10px] uppercase tracking-[0.3em] text-primary">Infrastructure IA</span>
            <h2 class="font-headline text-7xl font-bold text-on-surface leading-[0.82] mt-2">{p.name}</h2>
            <span class="font-body text-sm text-on-surface-variant mt-3 block max-w-[220px]">1500+ sessions, 50+ projets, une memoire qui persiste</span>
          </div>
          <div class="absolute top-5 right-5 flex items-baseline gap-1" style="z-index:2;">
            <span class="font-headline text-xs font-bold text-primary">1500+</span>
            <span class="font-headline text-[8px] uppercase tracking-wider text-on-surface-variant">sessions</span>
          </div>
        </div>
      );
    })()}

    <!-- JAJA hero (c4-6, r1-2) -->
    {(() => {
      const p = getProject("jaja")!;
      return (
        <div
          class="bento-tile bento-bg-coral grain-paper flex flex-col justify-end p-10 overflow-hidden"
          style="grid-column: 4 / 7; grid-row: 1 / 3;"
          data-slug={p.slug}
        >
          <div class="absolute top-10 right-10 h-28 flex items-end gap-[3px] opacity-55" style="z-index:2;">
            {waveBars.map((h) => (
              <div class="w-1.5 rounded-full bg-brand-coral" style={`height: ${h * 4}px`}></div>
            ))}
          </div>
          <div class="absolute top-10 left-10 flex items-center gap-2" style="z-index:2;">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-coral animate-pulse"></span>
            <span class="font-headline text-[9px] uppercase tracking-[0.25em] text-on-surface-variant">live · voice · agents</span>
          </div>
          <div>
            <span class="font-headline text-[10px] uppercase tracking-[0.3em] text-on-surface-variant">Orchestration IA</span>
            <h2 class="font-headline text-[120px] font-bold text-on-surface leading-[0.75] mt-3 tracking-tighter">{p.name}</h2>
            <span class="font-body text-base text-on-surface-variant mt-3 block">L'assistant qui agit, pas qui cause.</span>
          </div>
        </div>
      );
    })()}

    <!-- Oignon Roscoff hero (c7-8, r1-2) -->
    {(() => {
      const p = getProject("oignon-roscoff-aop")!;
      return (
        <div
          class="bento-tile bento-bg-amber grain-coarse flex flex-col justify-end p-8 overflow-hidden"
          style="grid-column: 7 / 9; grid-row: 1 / 3;"
          data-slug={p.slug}
        >
          <div class="absolute top-5 right-5 font-headline text-[42px] font-bold text-brand-amber leading-none" style="z-index:2;">-80<span class="text-xl">%</span></div>
          <div>
            <span class="font-headline text-[10px] uppercase tracking-[0.3em] text-on-surface-variant">AOP · Filiere agricole</span>
            <h2 class="font-headline text-[38px] font-bold text-on-surface leading-[0.85] mt-2">Oignon<br />de Roscoff</h2>
            <span class="font-body text-[11px] text-on-surface-variant mt-3 block">29 mois de prod · 100 producteurs</span>
          </div>
        </div>
      );
    })()}

    <!-- Skeletonify (c1 r2) -->
    {(() => {
      const p = getProject("skeletonify")!;
      return (
        <div
          class="bento-tile bg-surface-container grain-paper flex flex-col justify-end p-4 overflow-hidden"
          style="grid-column: 1; grid-row: 2;"
          data-slug={p.slug}
        >
          <div class="absolute top-3 left-3 right-3 space-y-1.5 opacity-40" style="z-index:2;">
            <div class="h-1.5 rounded-full bg-outline-variant w-full"></div>
            <div class="h-1.5 rounded-full bg-outline-variant w-3/4"></div>
            <div class="h-1.5 rounded-full bg-outline-variant w-5/6"></div>
          </div>
          <h3 class="font-headline text-sm font-bold text-on-surface leading-tight">Skeletonify</h3>
          <span class="font-headline text-[8px] text-outline uppercase tracking-wider mt-0.5">Anonym. IA</span>
        </div>
      );
    })()}

    <!-- ================= ROW 3-4 : MEDIUM + HERO VERTICAL ================= -->

    <!-- Uptake hero vertical (c1-2, r3-4) -->
    {(() => {
      const p = getProject("uptake")!;
      return (
        <div
          class="bento-tile grain-kraft flex flex-col justify-end p-7 overflow-hidden bg-on-surface"
          style="grid-column: 1 / 3; grid-row: 3 / 5;"
          data-slug={p.slug}
        >
          <div class="absolute inset-0 bg-gradient-to-br from-brand-cyan/20 via-transparent to-on-surface/60" style="z-index:0;"></div>
          <div class="absolute top-6 right-6" style="z-index:2;">
            <span class="material-symbols-outlined text-2xl text-brand-cyan">translate</span>
          </div>
          <div>
            <span class="font-headline text-[10px] uppercase tracking-[0.3em] text-brand-cyan">Web · IA · Apprentissage</span>
            <h2 class="font-headline text-[54px] font-bold text-white leading-[0.82] mt-2">{p.name}</h2>
            <span class="font-body text-xs text-brand-cyan mt-2 block">4 LLM orchestrés</span>
            <div class="mt-4 flex items-center gap-2">
              <div class="h-px w-8 bg-brand-cyan"></div>
              <span class="font-headline text-[9px] uppercase tracking-[0.2em] text-white/70">Anglais par articles réels</span>
            </div>
          </div>
        </div>
      );
    })()}

    <!-- Oligae (c3-4, r3) -->
    {(() => {
      const p = getProject("oligae")!;
      return (
        <div
          class="bento-tile bg-white grain-paper flex items-center justify-between px-6 overflow-hidden"
          style="grid-column: 3 / 5; grid-row: 3;"
          data-slug={p.slug}
        >
          <div>
            <span class="font-headline text-[9px] uppercase tracking-[0.25em] text-brand-coral">SaaS · ODG agricoles</span>
            <h2 class="font-headline text-3xl font-bold text-on-surface leading-[0.9] mt-1">{p.name}</h2>
            <div class="flex items-center gap-3 mt-1.5">
              <span class="font-headline text-[10px] text-outline"><span class="font-bold text-on-surface">2</span> prod</span>
              <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
              <span class="font-headline text-[10px] text-outline"><span class="font-bold text-on-surface">11</span> demos</span>
              <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
              <span class="font-headline text-[10px] text-outline"><span class="font-bold text-on-surface">1</span> mois</span>
            </div>
          </div>
          <div class="relative flex items-center justify-center w-16 h-16 rounded-full bg-brand-coral/10">
            <span class="material-symbols-outlined text-3xl text-brand-coral">hub</span>
          </div>
        </div>
      );
    })()}

    <!-- Karousel (c6-7, r3) -->
    {(() => {
      const p = getProject("karousel")!;
      return (
        <div
          class="bento-tile bg-surface-container-high grain-paper flex items-center px-5 overflow-hidden"
          style="grid-column: 6 / 8; grid-row: 3;"
          data-slug={p.slug}
        >
          <div>
            <span class="font-headline text-[9px] uppercase tracking-[0.2em] text-on-surface-variant">LinkedIn</span>
            <h2 class="font-headline text-2xl font-bold text-on-surface mt-0.5">{p.name}</h2>
            <span class="font-body text-[10px] text-outline mt-0.5 block">LLM + compilateur</span>
          </div>
          <div class="ml-auto flex gap-1.5">
            <span class="w-6 h-10 rounded-sm bg-primary/25"></span>
            <span class="w-6 h-10 rounded-sm bg-primary/50"></span>
            <span class="w-6 h-10 rounded-sm bg-primary/75"></span>
          </div>
        </div>
      );
    })()}

    <!-- Claude Analysis (c5 r3) -->
    {(() => {
      const p = getProject("claude-analysis")!;
      return (
        <div
          class="bento-tile bg-surface-container grain-paper flex flex-col justify-between p-4 overflow-hidden"
          style="grid-column: 5; grid-row: 3;"
          data-slug={p.slug}
        >
          <span class="material-symbols-outlined text-lg text-brand-amber">analytics</span>
          <div>
            <h3 class="font-headline text-sm font-bold text-on-surface leading-tight">{p.name}</h3>
            <span class="font-headline text-[8px] text-outline uppercase tracking-wider">mitmproxy {'>'} viewer</span>
          </div>
        </div>
      );
    })()}

    <!-- Creative open (c8 r3) -->
    <div
      class="bento-tile bg-white grain-paper creative-tile overflow-hidden"
      style="grid-column: 8; grid-row: 3;"
    >
      <svg class="creative-shapes" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
        <rect class="c-solid" x="20" y="26" width="22" height="22" rx="3"/>
        <rect class="c-solid" x="48" y="30" width="16" height="16" rx="3"/>
        <rect class="c-solid" x="24" y="54" width="14" height="14" rx="3"/>
        <rect class="c-open" x="44" y="52" width="28" height="22" rx="3"/>
      </svg>
      <span class="creative-bubble font-headline"></span>
    </div>

    <!-- Dictaphone (c4-5, r4) -->
    {(() => {
      const p = getProject("dictaphone")!;
      return (
        <div
          class="bento-tile bg-white grain-paper flex items-center gap-4 px-6 overflow-hidden"
          style="grid-column: 4 / 6; grid-row: 4;"
          data-slug={p.slug}
        >
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-on-surface">
            <span class="material-symbols-outlined text-white">mic</span>
          </div>
          <div class="flex-1">
            <h2 class="font-headline text-2xl font-bold text-on-surface leading-tight">{p.name}</h2>
            <div class="flex items-center gap-1.5 mt-0.5">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-coral"></span>
              <span class="font-headline text-[10px] text-outline uppercase tracking-wider">100% local</span>
            </div>
          </div>
          <div class="flex items-end gap-[2px] h-8">
            {dictWave.map((h) => (
              <div class="w-0.5 bg-on-surface rounded-full" style={`height: ${h * 3}px`}></div>
            ))}
          </div>
        </div>
      );
    })()}

    <!-- Epicycle Draw (c3 r4) -->
    {(() => {
      const p = getProject("epicycle-draw")!;
      return (
        <div
          class="bento-tile bg-white grain-paper flex flex-col justify-between p-4 overflow-hidden"
          style="grid-column: 3; grid-row: 4;"
          data-slug={p.slug}
        >
          <span class="material-symbols-outlined text-lg text-primary">donut_large</span>
          <div>
            <h3 class="font-headline text-sm font-bold text-on-surface leading-tight">{p.name}</h3>
            <span class="font-headline text-[8px] text-outline uppercase tracking-wider">Fourier {'>'} dessin</span>
          </div>
        </div>
      );
    })()}

    <!-- Vokable (c6 r4) -->
    {(() => {
      const p = getProject("vokable")!;
      return (
        <div
          class="bento-tile bg-surface-container-low grain-paper flex flex-col justify-between p-4 overflow-hidden"
          style="grid-column: 6; grid-row: 4;"
          data-slug={p.slug}
        >
          <span class="material-symbols-outlined text-lg text-brand-coral">graphic_eq</span>
          <div>
            <h3 class="font-headline text-sm font-bold text-on-surface-variant leading-tight">{p.name}</h3>
            <span class="font-headline text-[8px] text-outline uppercase tracking-wider">Voix {'>'} texte</span>
          </div>
        </div>
      );
    })()}

    <!-- Creative open (c7 r4) -->
    <div
      class="bento-tile bg-white grain-paper creative-tile overflow-hidden"
      style="grid-column: 7; grid-row: 4;"
    >
      <svg class="creative-shapes" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
        <rect class="c-solid" x="16" y="24" width="30" height="18" rx="3"/>
        <rect class="c-solid" x="52" y="24" width="18" height="18" rx="3"/>
        <rect class="c-solid" x="16" y="50" width="16" height="28" rx="3"/>
        <rect class="c-open" x="38" y="50" width="32" height="28" rx="3"/>
      </svg>
      <span class="creative-bubble font-headline"></span>
    </div>

    <!-- Creative open (c8 r4) -->
    <div
      class="bento-tile bg-white grain-paper creative-tile overflow-hidden"
      style="grid-column: 8; grid-row: 4;"
    >
      <svg class="creative-shapes" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
        <rect class="c-solid" x="22" y="22" width="22" height="30" rx="3"/>
        <rect class="c-solid" x="50" y="22" width="14" height="14" rx="3"/>
        <rect class="c-open" x="50" y="42" width="26" height="34" rx="3"/>
        <rect class="c-solid" x="22" y="58" width="22" height="18" rx="3"/>
      </svg>
      <span class="creative-label font-headline">lab ouvert</span>
      <span class="creative-bubble font-headline"></span>
    </div>

    <!-- ================= ROW 5 : UTILITY BAR ================= -->

    <!-- Expertise Avant-Projet (c1-2 r5) -->
    <div
      class="bento-tile bg-on-surface grain-kraft flex items-center gap-3 px-5 overflow-hidden group cursor-pointer"
      style="grid-column: 1 / 3; grid-row: 5;"
      data-info="expertise"
    >
      <div class="flex items-baseline gap-0.5">
        <span class="font-headline text-3xl font-bold text-brand-cyan leading-none">48</span>
        <span class="font-headline text-sm font-bold text-brand-cyan">h</span>
      </div>
      <div class="flex-1 min-w-0">
        <span class="font-headline text-[9px] uppercase tracking-[0.2em] text-white/60 block">Offre Koality</span>
        <span class="font-headline text-xs font-bold text-white leading-tight block">Expertise Avant-Projet</span>
      </div>
      <span class="material-symbols-outlined text-lg text-brand-cyan">arrow_forward</span>
    </div>

    <!-- AI stats (c3 r5) -->
    <div
      class="bento-tile bg-surface-container-high grain-paper flex flex-col items-center justify-center text-center px-2 overflow-hidden"
      style="grid-column: 3; grid-row: 5;"
      data-info="ai-stats"
    >
      <div class="flex items-baseline gap-0.5">
        <span class="font-headline text-xl font-bold text-primary leading-none">~</span>
        <span class="font-headline text-3xl font-bold text-on-surface leading-none">20</span>
      </div>
      <span class="font-headline text-[7px] uppercase tracking-[0.15em] text-outline mt-1 leading-tight block">produits IA<br />2025-26</span>
    </div>

    <!-- Context Collective (c4 r5) -->
    <div
      class="bento-tile bento-bg-cyan grain-paper flex flex-col items-center justify-center overflow-hidden"
      style="grid-column: 4; grid-row: 5;"
      data-info="context-collective"
    >
      <span class="material-symbols-outlined text-xl text-primary mb-0.5">hub</span>
      <span class="font-headline text-[11px] font-bold text-on-surface leading-tight text-center">Context<br/>Collective</span>
      <span class="font-headline text-[8px] uppercase tracking-[0.15em] text-on-surface-variant mt-0.5">Communauté IA</span>
    </div>

    <!-- Approche (c5 r5) -->
    <div
      class="bento-tile bento-bg-cyan grain-paper flex flex-col items-center justify-center text-center p-3 overflow-hidden"
      style="grid-column: 5; grid-row: 5;"
      data-info="approche"
    >
      <span class="font-headline text-[7px] uppercase tracking-[0.25em] text-primary mb-1">L'approche</span>
      <p class="font-headline text-[10px] font-semibold text-on-surface leading-tight">Des outils.<br />Pas des demos.</p>
    </div>

    <!-- Koality (c6 r5) -->
    <div
      class="bento-tile bento-bg-coral grain-coarse flex flex-col items-center justify-center overflow-hidden"
      style="grid-column: 6; grid-row: 5;"
      data-info="koality"
    >
      <span class="font-headline text-2xl font-bold text-brand-coral leading-none">K</span>
      <span class="font-headline text-[9px] font-bold text-on-surface mt-0.5">Koality</span>
      <span class="font-headline text-[7px] uppercase tracking-[0.2em] text-on-surface-variant">Co-fondateur</span>
    </div>

    <!-- Contact (c7-8 r5) -->
    <div
      class="bento-tile bg-on-surface grain-kraft flex items-center justify-center gap-3 group cursor-pointer overflow-hidden"
      style="grid-column: 7 / 9; grid-row: 5;"
      data-info="contact"
    >
      <div class="absolute top-2 right-2 w-1.5 h-1.5 rounded-full bg-brand-cyan"></div>
      <span class="material-symbols-outlined text-2xl text-white/80 group-hover:text-white transition-colors">mail</span>
      <div class="flex flex-col items-start">
        <span class="font-headline text-base font-bold text-white leading-tight">Ecrire</span>
        <span class="font-headline text-[9px] uppercase tracking-[0.25em] text-white/60">fabien@koality.fr</span>
      </div>
      <span class="material-symbols-outlined text-sm text-brand-cyan ml-2 group-hover:translate-x-1 transition-transform">arrow_forward</span>
    </div>
  </main>

  <!-- Modal -->
  <div id="modal" class="modal-backdrop" role="dialog" aria-modal="true">
    <button id="modal-close-outside" class="modal-close-outside" aria-label="Fermer">
      <span class="material-symbols-outlined" style="font-size:22px;">close</span>
    </button>
    <button id="modal-nav-prev" class="modal-nav-btn modal-nav-prev" aria-label="Projet précédent">
      <span class="material-symbols-outlined" style="font-size:22px;">chevron_left</span>
    </button>
    <button id="modal-nav-next" class="modal-nav-btn modal-nav-next" aria-label="Projet suivant">
      <span class="material-symbols-outlined" style="font-size:22px;">chevron_right</span>
    </button>
    <div class="modal-content relative" id="modal-inner">
      <div class="modal-controls">
        <button class="modal-drawer-toggle" id="modal-drawer-toggle" aria-label="Afficher/masquer les infos">
          <span class="material-symbols-outlined" style="font-size:20px;">side_navigation</span>
        </button>
        <button id="modal-close" aria-label="Fermer">
          <span class="material-symbols-outlined" style="font-size:20px;">close</span>
        </button>
      </div>
      <div class="modal-media" id="modal-media"></div>
      <div class="modal-info" id="modal-info"></div>
    </div>
  </div>

  <script define:vars={{ projects }}>
    const projectMap = {};
    projects.forEach((p) => {
      projectMap[p.slug] = p;
    });

    const modal = document.getElementById("modal");
    const modalInner = document.getElementById("modal-inner");
    const modalMedia = document.getElementById("modal-media");
    const modalInfo = document.getElementById("modal-info");
    const modalClose = document.getElementById("modal-close");
    const modalDrawerToggle = document.getElementById("modal-drawer-toggle");
    const modalNavPrev = document.getElementById("modal-nav-prev");
    const modalNavNext = document.getElementById("modal-nav-next");

    let navItems = [];
    let currentNavIdx = -1;

    const colorMap = {
      cyan: { accent: "#00d4ff", bg: "#e8fafe" },
      coral: { accent: "#ff7e67", bg: "#fff0ed" },
      amber: { accent: "#fbbc00", bg: "#fff8e1" },
    };

    // Info blocks (non-project tiles) — editorial layout
    const infoBlocks = {
      about: {
        visual: `<div style="font-family:'Space Grotesk'; font-size:120px; font-weight:700; color:#1b1c1a; line-height:0.8;">FC</div><div style="font-family:'Space Grotesk'; font-size:10px; text-transform:uppercase; letter-spacing:0.3em; color:#6e7880; margin-top:12px;">Lab · 2026</div>`,
        eyebrow: "Le lab",
        title: "Un terrain d'essai pour l'IA appliquée",
        body: "**Un terrain d'essai pour l'IA appliquée.** 11 projets, un objectif : mesurer ce que la technologie change vraiment dans un contexte métier.\n\n## Le fil\n\nVoix, transcription, agents, RAG, multi-LLM, orchestration. Des prototypes aux SaaS en production, chaque projet teste un usage concret.\n\n## Et ensuite\n\nCe qui passe l'épreuve du terrain nourrit les offres Koality côté clients PME : **Expertise Avant-Projet**, formation.",
        tags: ["Terrain d'essai", "IA appliquée", "PME"],
      },
      approche: {
        visual: `<div style="font-family:'Space Grotesk'; font-size:44px; font-weight:700; color:#1b1c1a; line-height:0.95; text-align:center;">Pas des démos.<br/><span style="color:#ff7e67;">Des outils.</span></div>`,
        eyebrow: "L'approche",
        title: "Ce qui guide le choix",
        body: "Une démo fonctionne une fois, devant un public préparé. **Un outil fonctionne tous les jours**, même quand personne ne regarde. La différence est immense : une démo peut masquer ses angles morts, un outil les révèle au premier usage réel.\n\n## Ce que cela implique\n\nMoins de fioritures, plus de tests en conditions réelles. Moins de *wow*, plus de *20 minutes gagnées par jour*. Les arbitrages se font toujours du côté de l'usage, jamais du côté du pitch.\n\n## Et l'IA dans tout ça\n\nL'IA est un levier, pas un sujet. Elle sert à faire passer un outil de *bien* à *excellent*, elle ne remplace pas le travail de conception. Le discernement sur **quoi construire** reste humain ; la vitesse d'exécution, elle, a changé d'échelle.",
        tags: ["Outil > démo", "Simple > clever", "Usage > pitch"],
      },
      "ai-stats": {
        visual: `<div style="font-family:'Space Grotesk'; font-size:140px; font-weight:700; color:#1b1c1a; line-height:0.8;"><span style="font-size:80px; color:#00d4ff; margin-right:8px;">~</span>20</div><div style="font-family:'Space Grotesk'; font-size:10px; text-transform:uppercase; letter-spacing:0.3em; color:#6e7880; margin-top:8px;">produits IA · 2025-2026</div>`,
        eyebrow: "Vélocité utile",
        title: "Une vingtaine de produits IA en 18 mois, et après ?",
        body: "**Ce chiffre n'est pas un trophée.** C'est le signe d'une chose plus intéressante : l'IA permet de **passer de l'idée au prototype utilisable en quelques jours**, pas en quelques mois. Pour un décideur, ça veut dire tester plus, douter plus tôt, décider sur du concret.\n\n## Ce que le lab prouve\n\nQue l'accélération est réelle, **à condition de savoir ce qu'on veut construire**. Le levier n'est pas la vitesse brute, c'est le fait de pouvoir vérifier une hypothèse avant de la budgéter.\n\n## Ce qui ne change pas\n\nLe travail de conception reste humain. **L'IA accélère l'exécution, elle ne décide pas ce qu'il faut construire.** Sans cadrage préalable, la vitesse ne sert qu'à se tromper plus vite.",
        tags: ["Vitesse utile", "Cadrage", "Usage réel"],
      },
      expertise: {
        visual: `<div style="display:flex; flex-direction:column; align-items:center;"><div style="display:flex; align-items:baseline; gap:6px;"><span style="font-family:'Space Grotesk'; font-size:120px; font-weight:700; color:#1b1c1a; line-height:0.8;">48</span><span style="font-family:'Space Grotesk'; font-size:48px; font-weight:700; color:#00d4ff;">h</span></div><div style="font-family:'Space Grotesk'; font-size:10px; text-transform:uppercase; letter-spacing:0.3em; color:#6e7880; margin-top:10px;">Expertise Avant-Projet · Koality</div></div>`,
        eyebrow: "Offre Koality",
        title: "Expertise Avant-Projet · 48h",
        body: "Avant d'engager plusieurs mois de développement ou quelques centaines de milliers d'euros, il existe une zone où l'on ne sait pas encore ce qu'on ne sait pas. **Le problème est-il bien posé ? La solution envisagée tient-elle la route ? La complexité a-t-elle été correctement estimée ?**\n\n## Le format\n\nL'Expertise Avant-Projet répond à ces questions en 48h. Un cadrage rapide, focalisé, conçu pour éviter de lancer un chantier sur une hypothèse bancale.\n\n## Le déroulé\n\nUn brief envoyé par le client, un échange d'une à deux heures pour poser le contexte, une journée de plongée dans le sujet, puis un document livrable qui identifie **ce qui tient**, **ce qui tangue**, **ce qui peut être sécurisé immédiatement** et **ce qui mérite une exploration avant d'engager plus**.\n\n## Pour qui\n\nUne offre Koality, conçue pour des décideurs qui veulent investir leurs ressources au bon endroit. Disponible pour des projets tech, IA, produit ou stratégie data.",
        tags: ["48h", "Cadrage", "Pré-projet"],
        links: [
          { label: "En savoir plus", href: "https://koality.fr/expertise-avant-projet", primary: true, icon: "arrow_forward" },
          { label: "LinkedIn", href: "https://www.linkedin.com/in/fabiencanu/", primary: false, icon: "link" },
          { label: "koality.fr", href: "https://koality.fr", primary: false, icon: "language" },
        ],
      },
      "context-collective": {
        visual: `<div style="display:flex; flex-direction:column; align-items:center;"><div style="width:96px; height:96px; border-radius:12px; background:#e8fafe; display:flex; align-items:center; justify-content:center;"><span class="material-symbols-outlined" style="font-size:52px; color:#006386;">hub</span></div><div style="font-family:'Space Grotesk'; font-size:30px; font-weight:700; color:#1b1c1a; margin-top:14px; line-height:1;">Context Collective</div><div style="font-family:'Space Grotesk'; font-size:10px; text-transform:uppercase; letter-spacing:0.3em; color:#6e7880; margin-top:6px;">Communauté IA · Brest</div></div>`,
        eyebrow: "Communauté",
        title: "Context Collective",
        body: "**Context Collective** est une communauté brestoise autour de l'IA appliquée. L'idée est simple : partager ce qui marche, ce qui rate, et les petits outils qu'on construit au passage, entre praticiens plutôt qu'entre théoriciens.\n\n## Pourquoi en parler ici\n\nUne partie des expériences du lab nourrit les échanges de la communauté, et inversement. Les discussions y sont concrètes, orientées usage, loin du bruit ambiant sur l'IA. C'est précieux quand on cherche à garder les pieds sur terre tout en explorant ce qui bouge vite.\n\n## Pour qui\n\nDéveloppeurs, designers, product, fondateurs, chercheurs. Brest et alentours, mais pas que : les échanges sont autant en ligne qu'en vrai.",
        tags: ["Communauté", "IA appliquée", "Brest"],
        links: [
          { label: "context-collective.org", href: "https://www.context-collective.org/", primary: true, icon: "language" },
        ],
      },
      koality: {
        visual: `<div style="display:flex; flex-direction:column; align-items:center;"><div style="width:88px; height:88px; border-radius:12px; background:#fff0ed; display:flex; align-items:center; justify-content:center;"><span style="font-family:'Space Grotesk'; font-size:44px; font-weight:700; color:#ff7e67;">K</span></div><div style="font-family:'Space Grotesk'; font-size:36px; font-weight:700; color:#1b1c1a; margin-top:12px;">Koality</div><div style="font-family:'Space Grotesk'; font-size:10px; text-transform:uppercase; letter-spacing:0.3em; color:#6e7880; margin-top:4px;">Structure · Co-fondateur</div></div>`,
        eyebrow: "Koality",
        title: "La structure, côté professionnel",
        body: "**Koality** est la structure que je co-anime depuis 2012. Elle accompagne des clients sur des projets tech et IA, parfois en construction, parfois en cadrage, parfois en renfort d'équipe.\n\n## Lab et missions\n\nLe lab présenté ici est un travail personnel mené en parallèle des missions. **La frontière est claire et volontaire** : d'un côté des projets clients avec leurs contraintes, de l'autre un terrain de jeu où peuvent être testées des idées qui ne rentreraient jamais dans un devis.\n\nCertaines idées remontent dans les offres Koality, d'autres restent des expériences utiles juste pour ce qu'elles ont appris.",
        tags: ["Co-fondateur", "Accompagnement", "Depuis 2012"],
        links: [
          { label: "koality.fr", href: "https://koality.fr", primary: true, icon: "language" },
          { label: "LinkedIn", href: "https://www.linkedin.com/in/fabiencanu/", primary: false, icon: "link" },
        ],
      },
      contact: {
        visual: `<div style="display:flex; flex-direction:column; align-items:center;"><span class="material-symbols-outlined" style="font-size:72px; color:#1b1c1a;">mail</span><div style="font-family:'Space Grotesk'; font-size:24px; font-weight:700; color:#1b1c1a; margin-top:12px;">fabien@koality.fr</div></div>`,
        eyebrow: "Contact",
        title: "Prise de contact",
        body: "**L'email reste le canal le plus efficace.** Réponse sous 48h en général, plus rapidement si le sujet est clair.\n\n## Ce qui fait gagner du temps\n\nUn message structuré en deux paragraphes : **le contexte**, **ce qui a déjà été essayé**, **ce qui est recherché**. Bien plus productif qu'un rendez-vous à froid.\n\n## Avant un appel\n\nUn premier échange écrit est toujours préférable avant de caler un créneau. Cela permet d'arriver préparé et d'éviter les rendez-vous exploratoires peu utiles.\n\n## Démarchage commercial\n\nLes sollicitations commerciales ne reçoivent pas de réponse. Merci de ne pas utiliser ce canal pour de la prospection.",
        tags: ["Email", "Réponse sous 48h", "Pas de prospection"],
        links: [
          { label: "Ecrire un email", href: "mailto:fabien@koality.fr", primary: true, icon: "mail" },
          { label: "LinkedIn", href: "https://www.linkedin.com/in/fabiencanu/", primary: false, icon: "link" },
          { label: "koality.fr", href: "https://koality.fr", primary: false, icon: "language" },
          { label: "GitHub", href: "https://github.com/cladjidane", primary: false, icon: "code" },
        ],
      },
    };

    function renderBody(text) {
      const boldify = (s) => s.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
      const blocks = text
        .split(/\n\n+/)
        .map((b) => b.trim())
        .filter((b) => b && !b.startsWith("## "));
      let leadUsed = false;
      return blocks
        .map((block) => {
          const cls = !leadUsed ? "prose-lead" : "prose-body";
          leadUsed = true;
          return '<p class="' + cls + '">' + boldify(block) + "</p>";
        })
        .join("");
    }

    function renderSingleMedia(m, name, noCaption) {
      let html = "";
      if (m.type === "gif" || m.type === "screenshot" || m.type === "diagram" || m.type === "split" || m.type === "mockup") {
        html = `<img src="${m.src}" alt="${name}" loading="lazy" />`;
      } else if (m.type === "video") {
        html = `<div class="video-wrapper" style="position:relative;">
          <video src="${m.src}" ${m.poster ? `poster="${m.poster}"` : ""} muted loop playsinline preload="metadata" style="border-radius:0.5rem;"></video>
          <button class="play-btn" style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:64px; height:64px; border-radius:50%; background:rgba(27,28,26,0.7); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; transition: opacity 200ms;">
            <span class="material-symbols-outlined" style="font-size:32px; color:#fff; margin-left:3px;">play_arrow</span>
          </button>
        </div>`;
      }
      if (!noCaption && m.caption) {
        html += `<div class="modal-caption-bar" data-toggle-drawer>
          <span class="caption-text">${m.caption}</span>
          <span class="material-symbols-outlined">chevron_right</span>
        </div>`;
      }
      return html;
    }

    function openModal(slug) {
      const p = projectMap[slug];
      if (!p) return;
      currentNavIdx = navItems.findIndex((it) => it.type === "project" && it.id === slug);

      const colors = colorMap[p.tagColor] || colorMap.cyan;

      // Media
      let mediaHtml = "";
      if (p.media && p.media.length > 0) {
        if (p.media.length === 1) {
          const m = p.media[0];
          mediaHtml = renderSingleMedia(m, p.name);
        } else {
          // Carousel for multiple media
          mediaHtml = `<div class="carousel-container" style="display:flex; flex-direction:column; width:100%; height:100%; min-height:0;">
            <div class="carousel-viewport" style="flex:1; min-height:0; display:flex; align-items:center; justify-content:center; position:relative;">
              ${p.media.map((m, i) => `<div class="carousel-slide" data-index="${i}" style="display:${i === 0 ? 'flex' : 'none'}; align-items:center; justify-content:center; width:100%; height:100%;">${renderSingleMedia(m, p.name, true)}</div>`).join("")}
            </div>
            <div class="carousel-bar" style="display:flex; align-items:center; justify-content:space-between; gap:12px; padding:12px 0 0;">
              <span class="carousel-caption-text" style="font-family:'Manrope'; font-size:13px; color:#6e7880; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; min-width:0; flex:1;">${p.media[0].caption || ""}</span>
              <div style="display:flex; align-items:center; gap:8px; flex-shrink:0;">
                <span class="carousel-counter" style="font-family:'Space Grotesk'; font-size:12px; color:#9ca3af; letter-spacing:0.05em; tabular-nums;">1 / ${p.media.length}</span>
                <button class="carousel-prev-btn" style="width:36px; height:36px; border-radius:50%; background:#1b1c1a; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;">
                  <span class="material-symbols-outlined" style="font-size:18px; color:#fff;">chevron_left</span>
                </button>
                <button class="carousel-next-btn" style="width:36px; height:36px; border-radius:50%; background:#1b1c1a; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;">
                  <span class="material-symbols-outlined" style="font-size:18px; color:#fff;">chevron_right</span>
                </button>
              </div>
            </div>
          </div>`;
        }
      } else if (p.thumbnail) {
        mediaHtml = `<img src="${p.thumbnail}" alt="${p.name}" loading="lazy" />`;
      } else {
        mediaHtml = `<div style="display:flex; align-items:center; justify-content:center; width:100%; height:200px; font-family:'Space Grotesk'; font-size:48px; font-weight:700; color:#e4e2de;">${p.name.substring(0, 2)}</div>`;
      }
      modalMedia.innerHTML = mediaHtml;

      // Info
      const tags = p.tags
        .map(
          (t) =>
            `<span style="background:${colors.bg}; color:${colors.accent}; padding:4px 10px; border-radius:4px; font-family:'Space Grotesk'; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">${t}</span>`
        )
        .join("");

      const techStack = p.techStack
        .map(
          (t) =>
            `<span style="background:#f0eeea; padding:3px 8px; border-radius:4px; font-family:'Space Grotesk'; font-size:10px; font-weight:500; color:#6e7880; letter-spacing:0.04em;">${t}</span>`
        )
        .join("");

      modalInfo.classList.remove("details-open");
      modalInfo.innerHTML = `
        <div class="modal-info-header">
          <div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:16px;">${tags}</div>
          <h2 style="font-family:'Space Grotesk'; font-size:36px; font-weight:700; color:#1b1c1a; line-height:1; margin-bottom:16px;">${p.name}</h2>
          <p class="modal-hook">${p.descriptionFr}</p>
        </div>
        <div class="modal-info-body">
          <button type="button" class="modal-details-toggle" aria-expanded="false">
            <span class="modal-details-label">Voir les détails</span>
            <span class="material-symbols-outlined modal-details-arrow">expand_more</span>
          </button>
          <div class="modal-details">${renderBody(p.about)}</div>
          <div class="modal-techstack" style="display:flex; gap:6px; flex-wrap:wrap;">${techStack}</div>
        </div>
      `;

      const detailsToggle = modalInfo.querySelector(".modal-details-toggle");
      const detailsBlock = modalInfo.querySelector(".modal-details");
      if (detailsToggle && detailsBlock) {
        detailsToggle.addEventListener("click", () => {
          const isOpen = modalInfo.classList.toggle("details-open");
          detailsToggle.classList.toggle("open", isOpen);
          detailsBlock.classList.toggle("open", isOpen);
          detailsToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
          detailsToggle.querySelector(".modal-details-label").textContent = isOpen ? "Réduire" : "Voir les détails";
        });
      }

      modalInner.classList.remove("info-layout");
      modal.classList.add("active");
      modalInner.classList.remove("expanded");
      modalInfo.scrollTop = 0;
      const infoBodyEl = modalInfo.querySelector(".modal-info-body");
      if (infoBodyEl) infoBodyEl.scrollTop = 0;
      document.body.style.overflow = "hidden";

      requestAnimationFrame(() => {
        const isMobile = () => window.matchMedia("(max-width: 767px)").matches;
        const video = modalMedia.querySelector("video");
        const playBtn = modalMedia.querySelector(".play-btn");
        if (video && playBtn) {
          function startVideo() {
            video.muted = false;
            video.play();
            video.setAttribute("controls", "");
            playBtn.style.opacity = "0";
            playBtn.style.pointerEvents = "none";
            if (!isMobile()) modalInner.classList.add("expanded");
          }
          playBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            startVideo();
          });
          video.addEventListener("click", (e) => {
            e.stopPropagation();
            if (!video.hasAttribute("controls")) {
              startVideo();
            }
          });
        }
        const img = modalMedia.querySelector("img:not(.carousel-slide img)");
        if (img) {
          img.addEventListener("click", (e) => {
            e.stopPropagation();
            if (!isMobile()) modalInner.classList.toggle("expanded");
          });
        }

        // Carousel controls
        const carouselContainer = modalMedia.querySelector(".carousel-container");
        if (carouselContainer) {
          const slides = carouselContainer.querySelectorAll(".carousel-slide");
          const captionText = carouselContainer.querySelector(".carousel-caption-text");
          const counter = carouselContainer.querySelector(".carousel-counter");
          const prevBtn = carouselContainer.querySelector(".carousel-prev-btn");
          const nextBtn = carouselContainer.querySelector(".carousel-next-btn");
          let idx = 0;
          const total = slides.length;

          function showSlide(newIdx) {
            slides[idx].style.display = "none";
            idx = (newIdx + total) % total;
            slides[idx].style.display = "flex";
            if (captionText) captionText.textContent = p.media[idx].caption || "";
            if (counter) counter.textContent = `${idx + 1} / ${total}`;
          }

          prevBtn.addEventListener("click", (e) => { e.stopPropagation(); showSlide(idx - 1); });
          nextBtn.addEventListener("click", (e) => { e.stopPropagation(); showSlide(idx + 1); });

          // Click on slide image to expand
          slides.forEach((slide) => {
            slide.addEventListener("click", (e) => {
              e.stopPropagation();
              modalInner.classList.toggle("expanded");
            });
          });
        }
      });
    }

    function openInfoModal(id) {
      const info = infoBlocks[id];
      if (!info) return;
      currentNavIdx = navItems.findIndex((it) => it.type === "info" && it.id === id);

      modalMedia.innerHTML = `<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; text-align:center;">${info.visual}</div>`;

      const tags = (info.tags || [])
        .map(
          (t) =>
            `<span style="background:#f5f3ef; color:#3e484f; padding:5px 11px; border-radius:4px; font-family:'Space Grotesk'; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em;">${t}</span>`
        )
        .join("");

      let linksHtml = "";
      if (info.links && info.links.length) {
        linksHtml =
          '<div style="display:flex; flex-direction:column; gap:8px; margin-top:24px;">' +
          info.links
            .map((l) => {
              const bg = l.primary ? "#1b1c1a" : "transparent";
              const color = l.primary ? "#fff" : "#1b1c1a";
              const border = l.primary ? "1px solid #1b1c1a" : "1px solid #e4e2de";
              return `<a href="${l.href}" target="_blank" rel="noopener" style="display:inline-flex; align-items:center; gap:10px; background:${bg}; color:${color}; border:${border}; padding:12px 18px; border-radius:6px; font-family:'Space Grotesk'; font-size:13px; font-weight:600; text-decoration:none; letter-spacing:0.02em;"><span class="material-symbols-outlined" style="font-size:18px;">${l.icon}</span>${l.label}</a>`;
            })
            .join("") +
          "</div>";
      }

      const bodyHtml = renderBody(info.body);

      modalInfo.innerHTML = `
        <div class="info-body" style="margin:0 auto;">
          <span style="font-family:'Space Grotesk'; font-size:10px; text-transform:uppercase; letter-spacing:0.3em; color:#6e7880; display:block; margin-bottom:10px;">${info.eyebrow}</span>
          <h2 style="font-family:'Space Grotesk'; font-size:36px; font-weight:700; color:#1b1c1a; line-height:1.05; margin-bottom:24px; letter-spacing:-0.01em;">${info.title}</h2>
          ${bodyHtml}
          <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:20px;">${tags}</div>
          ${linksHtml}
        </div>
      `;

      modalInner.classList.add("info-layout");
      modalInner.classList.remove("expanded");
      modal.classList.add("active");
      modalInfo.scrollTop = 0;
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modal.classList.remove("active");
      modalInner.classList.remove("expanded");
      modalInner.classList.remove("info-layout");
      document.body.style.overflow = "";
      const video = modalMedia.querySelector("video");
      if (video) {
        video.pause();
        video.currentTime = 0;
      }
    }

    modalDrawerToggle.addEventListener("click", () => {
      modalInner.classList.toggle("expanded");
    });

    modalMedia.addEventListener("click", (e) => {
      const captionBar = e.target.closest("[data-toggle-drawer]");
      if (captionBar) {
        e.stopPropagation();
        modalInner.classList.toggle("expanded");
      }
    });

    navItems = Array.from(document.querySelectorAll("[data-slug], [data-info]")).map((el) => ({
      type: el.hasAttribute("data-slug") ? "project" : "info",
      id: el.dataset.slug || el.dataset.info,
    }));

    document.querySelectorAll("[data-slug]").forEach((tile) => {
      tile.addEventListener("click", () => openModal(tile.dataset.slug));
    });
    document.querySelectorAll("[data-info]").forEach((tile) => {
      tile.addEventListener("click", (e) => {
        e.stopPropagation();
        openInfoModal(tile.dataset.info);
      });
    });

    modalClose.addEventListener("click", closeModal);
    document.getElementById("modal-close-outside")?.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    function navigateModal(dir) {
      if (currentNavIdx === -1 || navItems.length === 0) return;
      const newIdx = (currentNavIdx + dir + navItems.length) % navItems.length;
      const item = navItems[newIdx];
      if (item.type === "project") openModal(item.id);
      else openInfoModal(item.id);
    }

    modalNavPrev.addEventListener("click", (e) => { e.stopPropagation(); navigateModal(-1); });
    modalNavNext.addEventListener("click", (e) => { e.stopPropagation(); navigateModal(1); });

    document.addEventListener("keydown", (e) => {
      if (!modal.classList.contains("active")) return;
      if (e.key === "Escape") closeModal();
      if (e.key === "ArrowLeft") navigateModal(-1);
      if (e.key === "ArrowRight") navigateModal(1);
    });

    // Easter egg : click on empty creative tiles — non-repeating random whispers, per tile
    const whispers = [
      "chuuut ça mijote",
      "work in progress",
      "à suivre",
      "prochaine idée",
      "en incubation",
      "le vide est fertile",
      "laissez mijoter",
      "hors menu",
      "atelier ouvert",
      "brainstorming silencieux",
      "une piste creuse ici",
      "idée n°∞",
      "esquisse mentale",
      "la meilleure case",
      "zone franche",
      "pas encore nommé",
    ];
    let creativeClicks = 0;
    let lastWhisper = -1;
    document.querySelectorAll(".creative-tile").forEach((tile) => {
      const bubble = tile.querySelector(".creative-bubble");
      const open = tile.querySelector(".c-open");
      tile.addEventListener("click", () => {
        creativeClicks++;
        let msg;
        if (creativeClicks >= 7) {
          msg = "bravo, tu cliques sur du vide";
        } else {
          let idx;
          do {
            idx = Math.floor(Math.random() * whispers.length);
          } while (idx === lastWhisper && whispers.length > 1);
          lastWhisper = idx;
          msg = whispers[idx];
        }
        bubble.textContent = msg;
        bubble.classList.remove("show");
        void bubble.offsetWidth;
        bubble.classList.add("show");
        if (open) {
          open.classList.remove("wiggle");
          void open.getBoundingClientRect();
          open.classList.add("wiggle");
        }
      });
    });
  </script>
</Layout>
