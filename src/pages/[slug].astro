---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/projects";
import type { Project, ProjectMedia } from "../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

const colorMap = {
  cyan: { bg: "bg-brand-cyan", text: "text-brand-cyan", bgLight: "bg-brand-cyan/10", border: "border-brand-cyan/20" },
  amber: { bg: "bg-brand-amber", text: "text-brand-amber", bgLight: "bg-brand-amber/10", border: "border-brand-amber/20" },
  coral: { bg: "bg-brand-coral", text: "text-brand-coral", bgLight: "bg-brand-coral/10", border: "border-brand-coral/20" },
};
const colors = colorMap[project.tagColor];

const idx = projects.findIndex((p) => p.slug === project.slug);
const prev = idx > 0 ? projects[idx - 1] : null;
const next = idx < projects.length - 1 ? projects[idx + 1] : null;

const hasMedia = project.media && project.media.length > 0;
const hasVideo = !hasMedia;
---

<Layout title={`${project.name} · Lab IA Fabien Canu`} description={project.descriptionFr} image={project.thumbnail ?? "/images/og-image.png"} type="article">
  <Nav />

  <article class="pt-32 pb-20 max-w-5xl mx-auto px-8">
    <!-- Back link -->
    <a href="/" class="inline-flex items-center gap-2 text-on-surface-variant/60 hover:text-primary font-body text-sm transition-colors mb-12 group">
      <span class="material-symbols-outlined text-base group-hover:-translate-x-1 transition-transform">arrow_back</span>
      Retour au lab
    </a>

    <!-- Header -->
    <header class="mb-16">
      <div class="flex flex-wrap gap-2 mb-6">
        {project.tags.map((tag) => (
          <span class:list={["font-headline text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider", colors.bgLight, colors.text]}>
            {tag}
          </span>
        ))}
      </div>
      <h1 class="font-headline font-bold text-5xl md:text-7xl tracking-tighter mb-6">{project.name}</h1>
      <p class="font-body text-xl md:text-2xl text-on-surface-variant font-light leading-relaxed max-w-3xl">
        {project.descriptionFr}
      </p>
    </header>

    <!-- Media showcase -->
    <section class="mb-20">
      {hasMedia ? (
        <div class="media-carousel">
          {project.media!.map((m, i) => (
            <div class:list={["media-slide", i > 0 ? "hidden" : ""]} data-slide={i} data-caption={m.caption || ""}>
              {/* --- GIF --- */}
              {m.type === "gif" && (
                <figure class="rounded-2xl overflow-hidden bg-surface-container-high cursor-zoom-in" data-lightbox={m.src} data-lightbox-type="image">
                  <img src={m.src} alt={m.caption || project.name} class="w-full block" loading="lazy" />
                </figure>
              )}

              {/* --- VIDEO --- */}
              {m.type === "video" && (
                <figure class="rounded-2xl overflow-hidden bg-surface-container-high cursor-zoom-in" data-lightbox={m.src} data-lightbox-type="video">
                  <video class="w-full block" autoplay muted loop playsinline poster={m.poster}>
                    <source src={m.src} type="video/mp4" />
                  </video>
                </figure>
              )}

              {/* --- SPLIT --- */}
              {m.type === "split" && (
                <figure class="rounded-2xl overflow-hidden bg-on-surface cursor-zoom-in" data-lightbox={m.src} data-lightbox-type="image">
                  <div class="relative">
                    <img src={m.src} alt={m.caption || project.name} class="w-full block" loading="lazy" />
                    <div class="absolute inset-y-0 left-1/2 w-px bg-white/30"></div>
                    <div class="absolute top-4 left-4 bg-black/50 text-white text-[11px] font-headline font-bold uppercase tracking-wider px-3 py-1 rounded">Moderne</div>
                    <div class="absolute top-4 right-4 bg-black/50 text-white text-[11px] font-headline font-bold uppercase tracking-wider px-3 py-1 rounded">XIXe</div>
                  </div>
                </figure>
              )}

              {/* --- MOCKUP --- */}
              {m.type === "mockup" && (
                <figure class="py-8 cursor-zoom-in" data-lightbox={m.src} data-lightbox-type="image">
                  <div class="mx-auto max-w-sm">
                    <div class="bg-on-surface rounded-[3rem] p-3 shadow-2xl">
                      <div class="bg-black rounded-[2.5rem] overflow-hidden relative">
                        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-7 bg-on-surface rounded-b-2xl z-10"></div>
                        <img src={m.src} alt={m.caption || project.name} class="w-full block" loading="lazy" />
                      </div>
                    </div>
                  </div>
                </figure>
              )}

              {/* --- DIAGRAM --- */}
              {m.type === "diagram" && (
                <figure class="rounded-2xl overflow-hidden bg-surface-container-low border border-outline-variant/10 cursor-zoom-in" data-lightbox={m.src} data-lightbox-type="image">
                  <div class="p-4">
                    <img src={m.src} alt={m.caption || project.name} class="w-full block rounded-xl" loading="lazy" />
                  </div>
                </figure>
              )}

              {/* --- SCREENSHOT --- */}
              {m.type === "screenshot" && (
                <figure class="rounded-2xl overflow-hidden bg-surface-container-high shadow-lg cursor-zoom-in" data-lightbox={m.src} data-lightbox-type="image">
                  <img src={m.src} alt={m.caption || project.name} class="w-full block" loading="lazy" />
                </figure>
              )}
            </div>
          ))}

          {/* Controls bar: caption + counter + arrows */}
          {project.media!.length > 1 && (
            <div class="flex items-center justify-between mt-5 gap-4">
              <p class="carousel-caption font-body text-sm text-on-surface-variant min-w-0 truncate">
                {project.media![0].caption || ""}
              </p>
              <div class="flex items-center gap-2 shrink-0">
                <span class="carousel-counter font-headline text-sm text-on-surface-variant tracking-wider tabular-nums px-2">1 / {project.media!.length}</span>
                <button class="carousel-prev w-10 h-10 rounded-full bg-on-surface text-surface flex items-center justify-center hover:bg-on-surface/80 transition-colors" aria-label="Précédent">
                  <span class="material-symbols-outlined text-xl">chevron_left</span>
                </button>
                <button class="carousel-next w-10 h-10 rounded-full bg-on-surface text-surface flex items-center justify-center hover:bg-on-surface/80 transition-colors" aria-label="Suivant">
                  <span class="material-symbols-outlined text-xl">chevron_right</span>
                </button>
              </div>
            </div>
          )}
        </div>
      ) : (
        <div class="rounded-2xl overflow-hidden bg-surface-container-high aspect-video flex items-center justify-center relative group" id="video-container">
          <video
            class="w-full h-full object-cover hidden"
            controls
            preload="metadata"
            poster={`/videos/${project.slug}-poster.jpg`}
            id="demo-video"
          >
            <source src={`/videos/${project.slug}.mp4`} type="video/mp4" />
          </video>
          <div class="text-center" id="video-placeholder">
            <span class:list={["material-symbols-outlined text-7xl mb-4 block", colors.text]}>play_circle</span>
            <p class="font-headline text-sm uppercase tracking-widest text-on-surface-variant/40">Video a venir</p>
          </div>
        </div>
      )}

      {project.tryUrl && (
        <div class="mt-6 flex justify-center">
          <a href={project.tryUrl} target="_blank" rel="noopener" class:list={["inline-flex items-center gap-2 px-8 py-3 rounded font-headline font-bold text-sm uppercase tracking-wider text-on-primary transition-opacity hover:opacity-90", colors.bg]}>
            {project.tryLabel || "Essayer en live"}
            <span class="material-symbols-outlined text-base">north_east</span>
          </a>
        </div>
      )}
    </section>

    {hasVideo && (
      <script>
        const video = document.getElementById('demo-video') as HTMLVideoElement;
        const placeholder = document.getElementById('video-placeholder');
        if (video && placeholder) {
          video.addEventListener('loadedmetadata', () => {
            video.classList.remove('hidden');
            placeholder.classList.add('hidden');
          });
        }
      </script>
    )}

    <script>
      // Carousel
      const carousel = document.querySelector('.media-carousel');
      if (carousel) {
        const slides = carousel.querySelectorAll<HTMLElement>('.media-slide');
        const captionEl = carousel.querySelector<HTMLElement>('.carousel-caption');
        const counterEl = carousel.querySelector<HTMLElement>('.carousel-counter');
        const prevBtn = carousel.querySelector('.carousel-prev');
        const nextBtn = carousel.querySelector('.carousel-next');
        let current = 0;

        function goTo(index: number) {
          slides[current].classList.add('hidden');
          current = (index + slides.length) % slides.length;
          slides[current].classList.remove('hidden');
          if (captionEl) captionEl.textContent = slides[current].dataset.caption || '';
          if (counterEl) counterEl.textContent = `${current + 1} / ${slides.length}`;
        }

        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
      }

      // Lightbox
      const lightbox = document.getElementById('media-lightbox') as HTMLElement;
      const lbContent = document.getElementById('lightbox-content') as HTMLElement;
      const lbCaption = document.getElementById('lightbox-caption') as HTMLElement;
      const lbClose = document.getElementById('lightbox-close') as HTMLElement;
      const lbPrev = document.getElementById('lightbox-prev') as HTMLElement;
      const lbNext = document.getElementById('lightbox-next') as HTMLElement;
      const lbCounter = document.getElementById('lightbox-counter') as HTMLElement;

      if (lightbox) {
        const figures = document.querySelectorAll<HTMLElement>('figure[data-lightbox]');
        const items = Array.from(figures).map(f => ({
          src: f.dataset.lightbox!,
          type: f.dataset.lightboxType || 'image',
          caption: f.closest('.media-slide')?.nextElementSibling?.textContent || '',
        }));

        let lbCurrent = 0;
        const total = items.length;

        function openLightbox(index: number) {
          lbCurrent = index;
          renderLightbox();
          lightbox.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
          lightbox.classList.add('hidden');
          document.body.style.overflow = '';
          // Pause any playing video
          const vid = lbContent.querySelector('video');
          if (vid) vid.pause();
        }

        function renderLightbox() {
          const item = items[lbCurrent];
          if (item.type === 'video') {
            lbContent.innerHTML = `<video class="max-w-full max-h-[85vh] rounded-xl" autoplay loop muted playsinline controls><source src="${item.src}" type="video/mp4" /></video>`;
          } else {
            lbContent.innerHTML = `<img src="${item.src}" alt="" class="max-w-full max-h-[85vh] rounded-xl object-contain" />`;
          }
          if (lbCounter) lbCounter.textContent = `${lbCurrent + 1} / ${total}`;
          // Show/hide arrows
          if (lbPrev) lbPrev.style.display = total > 1 ? '' : 'none';
          if (lbNext) lbNext.style.display = total > 1 ? '' : 'none';
          if (lbCounter) lbCounter.style.display = total > 1 ? '' : 'none';
        }

        // Click on figure to open
        figures.forEach((fig, i) => {
          fig.addEventListener('click', () => openLightbox(i));
        });

        lbClose?.addEventListener('click', closeLightbox);
        lbPrev?.addEventListener('click', () => { lbCurrent = (lbCurrent - 1 + total) % total; renderLightbox(); });
        lbNext?.addEventListener('click', () => { lbCurrent = (lbCurrent + 1) % total; renderLightbox(); });

        // Close on backdrop click
        lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox) closeLightbox();
        });

        // Keyboard
        document.addEventListener('keydown', (e) => {
          if (lightbox.classList.contains('hidden')) return;
          if (e.key === 'Escape') closeLightbox();
          if (e.key === 'ArrowLeft' && total > 1) { lbCurrent = (lbCurrent - 1 + total) % total; renderLightbox(); }
          if (e.key === 'ArrowRight' && total > 1) { lbCurrent = (lbCurrent + 1) % total; renderLightbox(); }
        });
      }
    </script>

    <!-- About + Tech -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-20">
      <div class="md:col-span-2">
        <h2 class="font-headline font-bold text-2xl tracking-tight uppercase mb-6 flex items-center gap-3">
          <div class:list={["w-2 h-2 rounded-full", colors.bg]}></div>
          De quoi il s'agit
        </h2>
        <p class="font-body text-lg text-on-surface-variant leading-relaxed">
          {project.about}
        </p>
      </div>

      <div>
        <h2 class="font-headline font-bold text-2xl tracking-tight uppercase mb-6 flex items-center gap-3">
          <div class="w-2 h-2 rounded-full bg-on-surface-variant/30"></div>
          Stack
        </h2>
        <div class="flex flex-wrap gap-2">
          {project.techStack.map((tech) => (
            <span class="bg-surface-container-high px-3 py-1.5 rounded text-xs font-headline font-medium tracking-wider text-on-surface-variant">
              {tech}
            </span>
          ))}
        </div>

        <div class="mt-10 flex flex-col gap-3">
          {project.tryUrl && (
            <a href={project.tryUrl} class:list={["inline-flex items-center justify-center gap-2 px-6 py-3 rounded font-headline font-bold text-sm uppercase tracking-wider text-on-primary transition-opacity hover:opacity-90", colors.bg]}>
              {project.tryLabel || "Essayer"}
              <span class="material-symbols-outlined text-base">north_east</span>
            </a>
          )}
          {project.githubUrl && (
            <a href={project.githubUrl} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded font-headline font-bold text-sm uppercase tracking-wider bg-surface-container-highest text-on-surface-variant hover:text-on-surface transition-colors">
              Code source
              <span class="material-symbols-outlined text-base">north_east</span>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Prev/Next navigation -->
    <nav class="border-t border-outline-variant/10 pt-12 grid grid-cols-2 gap-8">
      {prev ? (
        <a href={`/${prev.slug}`} class="group">
          <span class="font-body text-xs uppercase tracking-widest text-on-surface-variant/40 mb-2 block">Precedent</span>
          <span class="font-headline font-bold text-xl group-hover:text-primary transition-colors">{prev.name}</span>
        </a>
      ) : <div />}
      {next ? (
        <a href={`/${next.slug}`} class="text-right group">
          <span class="font-body text-xs uppercase tracking-widest text-on-surface-variant/40 mb-2 block">Suivant</span>
          <span class="font-headline font-bold text-xl group-hover:text-primary transition-colors">{next.name}</span>
        </a>
      ) : <div />}
    </nav>
  </article>

  <!-- Lightbox modal -->
  <div id="media-lightbox" class="hidden fixed inset-0 z-50 bg-black/90 backdrop-blur-sm flex items-center justify-center p-4 md:p-8">
    <button id="lightbox-close" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10" aria-label="Fermer">
      <span class="material-symbols-outlined text-xl">close</span>
    </button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10" aria-label="Précédent">
      <span class="material-symbols-outlined text-xl">chevron_left</span>
    </button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10" aria-label="Suivant">
      <span class="material-symbols-outlined text-xl">chevron_right</span>
    </button>
    <div id="lightbox-content" class="flex items-center justify-center"></div>
    <span id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 font-headline text-xs text-white/50 tracking-wider tabular-nums"></span>
  </div>

  <Footer />
</Layout>
