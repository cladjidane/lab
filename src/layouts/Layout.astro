---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title = "Le lab IA de Fabien Canu",
  description = "Le lab IA de Fabien Canu. 25 ans de code et une vingtaine de produits sortis en 18 mois. PAI, Jaja, Uptake, Vokable et d'autres terrains d'essai.",
  image = "/images/og-image.png",
  type = "website",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://fabiencanu.fr");
const ogImageURL = new URL(image, Astro.site ?? "https://fabiencanu.fr").toString();
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />

    <meta name="author" content="Fabien Canu" />
    <meta name="theme-color" content="#fbf9f5" />
    <meta name="color-scheme" content="light" />
    <meta name="robots" content="index, follow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Le lab IA de Fabien Canu" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Le lab IA de Fabien Canu" />
    <meta property="og:locale" content="fr_FR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Le lab IA de Fabien Canu" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Manrope:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: "Fabien Canu",
      url: "https://fabiencanu.fr",
      jobTitle: "Concepteur IA · Co-fondateur Koality",
      description,
      sameAs: [
        "https://www.linkedin.com/in/fabien-canu/",
        "https://github.com/cladjidane",
        "https://koality.fr",
      ],
    })} />
  </head>
  <body class="bg-surface text-on-surface font-body selection:bg-brand-amber/30">
    <slot />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RJ4HWMYR45"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RJ4HWMYR45', { anonymize_ip: true });
    </script>

    <!-- Vercel Analytics (auto-injected en prod Vercel) -->
    <script defer src="/_vercel/insights/script.js"></script>
    <script defer src="/_vercel/speed-insights/script.js"></script>
  </body>
</html>
